#. module: dynamic_approval_workflow
#: model:mail.template,body_html:dynamic_approval_workflow.email_template_approval_request
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"        Dear {{ ctx.get('approver_name', 'Approver') }},\n"
"    </p>\n"
"    <br/>\n"
"    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"        An approval request requires your action:\n"
"    </p>\n"
"    <br/>\n"
"    <table style=\"border: 1px solid #dee2e6; border-collapse: collapse; width: 100%; font-size: 13px;\">\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight: bold; width: 35%;\">Reference</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\">{{ object.name }}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight: bold;\">Document</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\">{{ object.res_name }}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight: bold;\">Workflow</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\">{{ object.config_id.name }}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight: bold;\">Stage</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\">{{ object.current_stage_id.name }}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight: bold;\">Requested By</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\">{{ object.requester_id.name }}</td>\n"
"        </tr>\n"
"        {% if object.deadline %}\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6; background: #f8f9fa; font-weight: bold;\">Deadline</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6; color: #dc3545;\">{{ object.deadline }}</td>\n"
"        </tr>\n"
"        {% endif %}\n"
"    </table>\n"
"    <br/>\n"
"    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"        Please log in to Odoo and review the request at your earliest convenience.\n"
"    </p>\n"
"    <br/>\n"
"    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"        <a href=\"/web#model=approval.request&amp;id={{ object.id }}&amp;view_type=form\" style=\"background-color: #875A7B; color: #fff; padding: 8px 16px;&#10;                  text-decoration: none; border-radius: 4px; font-size: 13px;\">\n"
"            Review Request\n"
"        </a>\n"
"    </p>\n"
"    <br/>\n"
"    <p style=\"margin: 0px; padding: 0px; font-size: 12px; color: #6c757d;\">\n"
"        This is an automated notification from your Odoo system.\n"
"    </p>\n"
"</div>\n"
"        "
msgstr ""
"<div style=\"lề: 0px; phần đệm: 0px;\">\n"
"    <p style=\"margin: 0px; phần đệm: 0px; cỡ chữ: 13px;\">\n"
"        Kính gửi {{ ctx.get('approver_name', 'Approver') }},\n"
"    </p>\n"
"    <br/>\n"
"    <p style=\"margin: 0px; phần đệm: 0px; cỡ chữ: 13px;\">\n"
"        Yêu cầu phê duyệt yêu cầu hành động của bạn:\n"
"    </p>\n"
"    <br/>\n"
"    <table style=\"border: 1px Solid #dee2e6; border-collapse: thu gọn; chiều rộng: 100%; cỡ chữ: 13px;\">\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; đường viền: 1px Solid #dee2e6; nền: #f8f9fa; font-weight: đậm; chiều rộng: 35%;\">Tham khảo</td>\n"
"            <td style=\"padding: 8px 12px; đường viền: 1px liền khối #dee2e6;\">{{ object.name }}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; đường viền: 1px Solid #dee2e6; nền: #f8f9fa; font-weight: đậm;\">Tài liệu</td>\n"
"            <td style=\"padding: 8px 12px; đường viền: 1px liền khối #dee2e6;\">{{ object.res_name }}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; đường viền: 1px Solid #dee2e6; nền: #f8f9fa; font-weight: đậm;\">Quy trình làm việc</td>\n"
"            <td style=\"padding: 8px 12px; đường viền: 1px liền khối #dee2e6;\">{{ object.config_id.name }}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; đường viền: 1px Solid #dee2e6; nền: #f8f9fa; font-weight: đậm;\">Sân khấu</td>\n"
"            <td style=\"padding: 8px 12px; đường viền: 1px liền khối #dee2e6;\">{{ object.current_stage_id.name }}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; đường viền: 1px Solid #dee2e6; nền: #f8f9fa; font-weight: đậm;\">Được yêu cầu bởi</td>\n"
"            <td style=\"padding: 8px 12px; đường viền: 1px liền khối #dee2e6;\">{{ object.requester_id.name }}</td>\n"
"        </tr>\n"
"        {% if object.deadline %}\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; đường viền: 1px Solid #dee2e6; nền: #f8f9fa; font-weight: đậm;\">Hạn chót</td>\n"
"            <td style=\"padding: 8px 12px; đường viền: 1px liền khối #dee2e6; màu: #dc3545;\">{{ object.deadline }}</td>\n"
"        </tr>\n"
"        {% endif %}\n"
"    </bảng>\n"
"    <br/>\n"
"    <p style=\"margin: 0px; phần đệm: 0px; cỡ chữ: 13px;\">\n"
"        Vui lòng đăng nhập vào Odoo và xem xét yêu cầu trong thời gian sớm nhất có thể.\n"
"    </p>\n"
"    <br/>\n"
"    <p style=\"margin: 0px; phần đệm: 0px; cỡ chữ: 13px;\">\n"
"        <a href=\"/web#model=approval.request&amp;id={{ object.id }}&amp;view_type=form\" style=\"background-color: #875A7B; color: #fff; đệm: 8px 16px;&#10; trang trí văn bản: none; bán kính đường viền: 4px; cỡ chữ: 13px;\">\n"
"            Yêu cầu xem xét\n"
"        </a>\n"
"    </p>\n"
"    <br/>\n"
"    <p style=\"margin: 0px; phần đệm: 0px; cỡ chữ: 12px; màu: #6c757d;\">\n"
"        Đây là thông báo tự động từ hệ thống Odoo của bạn.\n"
"    </p>\n"
"</div>"

